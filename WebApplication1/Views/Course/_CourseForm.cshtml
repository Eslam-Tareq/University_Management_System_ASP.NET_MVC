@model CourseFormViewModel
<div class="form-group">
    <label asp-for="Name"></label>
    <input class="form-control" asp-for="Name">
        <span asp-validation-for="Name" class="text-danger"></span>
   
       
    </div>
    
    <div class="form-group">
        <label asp-for="Description"></label>
        <input class="form-control" asp-for="Description">
            <span asp-validation-for="Description" class="text-danger"></span>

        </div>
        <div class="form-group">
            <label asp-for="Grade"></label>
            <input class="form-control" asp-for="Grade">
                <span asp-validation-for="Grade" class="text-danger"></span>


            </div>
            <div class="form-group">
                <label asp-for="Mindegree"></label>
                <input class="form-control" asp-for="Mindegree">
                    <span asp-validation-for="Mindegree" class="text-danger"></span>


                </div>
                <div class="form-group">
                    <label asp-for="Topics"></label>
                    <input class="form-control" asp-for="Topics">
                        <span asp-validation-for="Topics" class="text-danger"></span>

                    </div>
   
  
   
                    <br />
