@model List<Course>
<partial name="_SuccessToast" />

<h1>Courses</h1>

<a class="btn btn-outline-primary" asp-action="New" asp-controller="Course">new</a>

<table class="table">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Name</th>
            <th scope="col">Description</th>
            <th scope="col">Grade</th>
            <th scope="col">Mindegree</th>
            <th scope="col">Details</th>
            <th scope="col">Edit</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                
                <th scope="row">@s.Crs_Id</th>
                <td>@s.Name</td>
                <td>@s.Description</td>
                <td>@s.Grade</td>
                <td>@s.Mindegree</td>
              
                <td>
                    <a class="link-dark" asp-action="Details" asp-controller="Course" asp-route-id="@s.Crs_Id">details</a>
                    </td>
                        <td><a class="link-dark" asp-action="Edit" asp-controller="Course" asp-route-id="@s.Crs_Id">Edit</a> </td>

                </tr>
            }

        </tbody>
    </table>